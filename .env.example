NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_ENV=development   # development | staging | production

# Demo mode (dev-only, read-only auth bypass)
DEMO_MODE=false                   # set to "true" to enable
DEMO_MODE_KEY=                    # secret key required in URL ?key=...
DEMO_ORG_ID=                      # UUID of the organisation to expose
